class_name EvaluationResult
## Holds the outcome of serving a customer.
## Generated by RecipeEvaluator; consumed by Customer for reactions.

## Overall quality score (0.0 to 1.0).
var overall_score: float = 0.0

## Per-axis scores (0.0 to 1.0).
var sweetness_score: float = 0.0
var strength_score: float = 0.0
var temperature_score: float = 0.0

## Ordered list of specific complaints, e.g., ["too_sweet", "not_cold_enough"].
## Empty if the drink is perfect.
var complaints: Array[String] = []

## True if all scores are near-perfect (>= 0.95).
var is_perfect: bool = false

## Human-readable summary for debug / UI.
var summary: String = ""
